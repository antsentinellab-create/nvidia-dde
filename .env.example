# Database Configuration
# Default: SQLite (backward compatible)
DATABASE_URL=sqlite:///db/history.db

# PostgreSQL Configuration (uncomment to use)
# DATABASE_URL=postgresql://user:password@localhost:5432/dss_db?pool_size=10&max_overflow=20

# Knowledge Base Remote Git Repository
# Optional: Set for team knowledge sharing
# KNOWLEDGE_REMOTE_URL=git@github.com:your-team/dss-knowledge.git

# Web Server Configuration
WEB_HOST=0.0.0.0
WEB_PORT=8000

# Async Task Configuration
MAX_WORKERS=3
